# Python
__pycache__/
*.py[cod]
.pytest_cache/
.ipynb_checkpoints/

# Virtual environments
.venv*/
venv/
env/
.repro_test_venv/
.verify_venv/

# OS
.DS_Store

# Editors
.vscode/
.idea/

# Do NOT commit PDFs, Word documents, or figures (kept out of version control by
# request). The manuscript (PDF/DOCX) and regenerated figures are distributed via
# the Zenodo deposit, not the git repository.
*.pdf
*.docx
figures/*
!figures/.gitkeep

# The entire manuscript/ folder (sources, figures, response letter, revision
# notes) is kept local only and is not tracked.
manuscript/

# Regenerated text outputs (tables/, data/processed/) ARE tracked so reviewers
# can see them without running the pipeline. Uncomment to treat as artifacts:
# tables/*.csv
# tables/*.md
# data/processed/
