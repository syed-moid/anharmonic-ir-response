&CONTROL
    calculation = 'scf',
    prefix = 'SrTiO3_defect',
    outdir = './tmp',
    pseudo_dir = './pseudo',
    tstress = .true.,
    tprnfor = .true.,
    restart_mode = 'restart',       ! Restarts from existing data in outdir
    wf_collect = .true.,
    disk_io = 'low',
/
&SYSTEM
    ibrav = 0,
    nat = 39,
    ntyp = 3,
    ecutwfc = 80.0,
    ecutrho = 320.0,
    occupations = 'smearing',
    smearing = 'gaussian',
    degauss = 0.005,
/
&ELECTRONS
    conv_thr = 1.0d-10,
    diagonalization = 'david',
    mixing_beta = 0.03,
/
