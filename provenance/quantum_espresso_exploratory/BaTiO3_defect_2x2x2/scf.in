&CONTROL
    calculation = 'scf',
    prefix = 'BaTiO3_defect',
    outdir = './tmp',
    pseudo_dir = './pseudo',
    tstress = .true.,
    tprnfor = .true.,
    restart_mode = 'restart',       ! Restarts from existing data in outdir
/
&SYSTEM
    ibrav = 0,
    nat = 39,
    ntyp = 3,
    ecutwfc = 80.0,
    ecutrho = 320.0,
    occupations = 'smearing',
    smearing = 'gaussian',
    degauss = 0.002,
/
&ELECTRONS
    conv_thr = 1.0d-7,
    diagonalization = 'david',
    mixing_beta = 0.5,
/
